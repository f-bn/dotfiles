# Font
font-family = "Ubuntu Sans Mono"
font-style = "Medium"
font-size = 12

# Theme
theme = "Tango Dark Custom"
background-opacity = 0.95
background-blur = true
bold-color = bright

# Window
window-padding-x = 8
window-padding-y = 8

# Cursor
cursor-style-blink = true
cursor-opacity = 1
adjust-cursor-thickness = 125%

# Bell
bell-features = no-attention,no-title

# Shell integrations
shell-integration-features = sudo,title,ssh-env,no-cursor

# Working directory
working-directory = home
window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true

# Keybinds
keybind = shift+ctrl+left=goto_split:left
keybind = shift+ctrl+right=goto_split:right
keybind = shift+ctrl+up=goto_split:top
keybind = shift+ctrl+down=goto_split:bottom

# Updates
auto-update = off