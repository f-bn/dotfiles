# - vim -
[vim-plug]
    type = "file"
    url = "https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim"
    targetPath = ".vim/autoload/plug.vim"
    refreshPeriod = "168h"

# - ohmyzsh and plugins -
[oh-my-zsh]
    type = "archive"
    url = "https://github.com/ohmyzsh/ohmyzsh/archive/master.tar.gz"
    targetPath = ".oh-my-zsh"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"

[zsh-autosuggestions]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-autosuggestions/archive/master.tar.gz"
    targetPath = ".oh-my-zsh/custom/plugins/zsh-autosuggestions"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"

# - Utilities -
[copilot]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "github/copilot-cli" "copilot-linux-x64.tar.gz" | quote }}
    path = "copilot"
    targetPath = ".local/bin/copilot"
    executable = true
    refreshPeriod = "24h"

[crane]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "google/go-containerregistry" "go-containerregistry_Linux_x86_64.tar.gz" | quote }}
    path = "crane"
    targetPath = ".local/bin/crane"
    executable = true
    refreshPeriod = "168h"

