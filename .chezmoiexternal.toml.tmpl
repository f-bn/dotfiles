    type = "archive"
    url = "https://github.com/89luca89/distrobox/archive/refs/tags/{{ (gitHubLatestRelease "89luca89/distrobox").TagName }}.tar.gz"
    targetPath = ".local/bin"
    stripComponents = 1
    include = ["*/distrobox", "*/distrobox-*"]
    refreshPeriod = "168h"

